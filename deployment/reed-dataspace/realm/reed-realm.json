{
  "realm": "REED",
  "enabled": true,
  "displayName": "REED Manufacturing Data Space",
  "sslRequired": "none",
  "registrationAllowed": false,
  "roles": {
    "realm": [
      { "name": "reed-admin", "description": "REED platform operator / break-glass" },
      { "name": "oem-manager", "description": "OEM data consumer manager" },
      { "name": "supplier-owner", "description": "Supplier data owner" },
      { "name": "service-provider", "description": "Simulation/optimization service provider" },
      { "name": "auditor", "description": "Read-only auditor" },
      { "name": "viewer", "description": "Read-only viewer" }
    ]
  },
  "clients": [
    {
      "clientId": "reed-supplier-api",
      "enabled": true,
      "publicClient": false,
      "secret": "reed-supplier-secret",
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "redirectUris": ["http://localhost:5173/*"],
      "webOrigins": ["http://localhost:5173"],
      "protocolMappers": [
        {
          "name": "bpn",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "config": {
            "user.attribute": "bpn",
            "claim.name": "bpn",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "reed-oem-api",
      "enabled": true,
      "publicClient": false,
      "secret": "reed-oem-secret",
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "redirectUris": ["http://localhost:5174/*"],
      "webOrigins": ["http://localhost:5174"],
      "protocolMappers": [
        {
          "name": "bpn",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "config": {
            "user.attribute": "bpn",
            "claim.name": "bpn",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    }
  ],
  "users": [
    {
      "username": "supplier-admin",
      "enabled": true,
      "email": "admin@reed-supplier.local",
      "firstName": "Supplier",
      "lastName": "Admin",
      "attributes": { "bpn": ["BPNLREEDSUPP0001"] },
      "credentials": [{ "type": "password", "value": "supplier", "temporary": false }],
      "realmRoles": ["supplier-owner", "reed-admin"]
    },
    {
      "username": "oem-buyer",
      "enabled": true,
      "email": "buyer@reed-oem.local",
      "firstName": "OEM",
      "lastName": "Buyer",
      "attributes": { "bpn": ["BPNLREEDOEM00001"] },
      "credentials": [{ "type": "password", "value": "oem", "temporary": false }],
      "realmRoles": ["oem-manager"]
    }
  ]
}
